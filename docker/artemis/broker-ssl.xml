<?xml version='1.0'?>
<!--
    ActiveMQ Artemis broker configuration for SSL OpenWire integration testing.

    SSL-only: exposes a single OpenWire acceptor on port 61617 with TLS enabled.
    No plaintext acceptors are configured (matching Classic's activemq-ssl.xml).

    The broker keystore and truststore are the same PKCS12 files generated by
    docker/ssl/generate-certs-entrypoint.sh. They are mounted directly at
    /opt/artemis-certs/ in the container (not via etc-override) so the broker
    can read them regardless of how the image's entrypoint handles overrides.

    Advisory topic support and virtual topic consumer wildcard translation are
    configured identically to broker.xml so the SSL suite exercises the same
    feature set as the plaintext suite.
-->
<configuration xmlns="urn:activemq"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="urn:activemq /schema/artemis-configuration.xsd">

  <core xmlns="urn:activemq:core"
        xsi:schemaLocation="urn:activemq:core ">

    <name>activemq-artemis-ssl-test</name>

    <!-- Persistence enabled so the broker journals XA prepared transactions
         (XA requires durable storage for two-phase commit recovery). -->
    <persistence-enabled>true</persistence-enabled>
    <security-enabled>false</security-enabled>

    <!-- Raise the disk-full threshold so the broker does not block producers
         when the host filesystem is heavily utilised (Artemis default is 90%).
         Integration-test messages are tiny so the ephemeral data directory
         will never actually fill the disk. -->
    <max-disk-usage>99</max-disk-usage>

    <acceptors>
      <!-- SSL OpenWire acceptor on port 61617 (SSL-only, no plaintext).
           supportAdvisory=true and virtualTopicConsumerWildcards mirror the
           plain broker.xml configuration so the SSL suite tests the same
           advisory and virtual-topic features. -->
      <acceptor name="openwire-ssl">tcp://0.0.0.0:61617?protocols=OPENWIRE;sslEnabled=true;keyStorePath=/opt/artemis-certs/broker.p12;keyStorePassword=password;keyStoreType=PKCS12;trustStorePath=/opt/artemis-certs/broker-truststore.p12;trustStorePassword=password;trustStoreType=PKCS12;needClientAuth=false;supportAdvisory=true;suppressInternalManagementObjects=false;virtualTopicConsumerWildcards=Consumer.*.%3E%3B2;tcpSendBufferSize=1048576;tcpReceiveBufferSize=1048576;connectionsAllowed=20000</acceptor>
    </acceptors>

    <addresses>
      <address name="ActiveMQ.DLQ">
        <anycast>
          <queue name="ActiveMQ.DLQ"/>
        </anycast>
      </address>
      <address name="ExpiryQueue">
        <anycast>
          <queue name="ExpiryQueue"/>
        </anycast>
      </address>
    </addresses>

    <address-settings>
      <address-setting match="#">
        <dead-letter-address>ActiveMQ.DLQ</dead-letter-address>
        <expiry-address>ExpiryQueue</expiry-address>
        <auto-create-queues>true</auto-create-queues>
        <auto-create-addresses>true</auto-create-addresses>
        <auto-delete-queues>false</auto-delete-queues>
        <auto-delete-addresses>false</auto-delete-addresses>
        <max-size-bytes>-1</max-size-bytes>
        <message-counter-history-day-limit>10</message-counter-history-day-limit>
      </address-setting>
    </address-settings>

  </core>
</configuration>
