<?xml version='1.0'?>
<!--
    ActiveMQ Artemis broker configuration for SSL OpenWire integration testing.

    SSL-only: exposes a single OpenWire acceptor on port 61617 with TLS enabled.
    No plaintext acceptors are configured (matching Classic's activemq-ssl.xml).

    The broker keystore and truststore are the same PKCS12 files generated by
    docker/ssl/generate-certs-entrypoint.sh and mounted into this container at
    /var/lib/artemis-broker/etc/certs/.
-->
<configuration xmlns="urn:activemq"
               xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:schemaLocation="urn:activemq /schema/artemis-configuration.xsd">

  <core xmlns="urn:activemq:core"
        xsi:schemaLocation="urn:activemq:core ">

    <name>activemq-artemis-ssl-test</name>

    <persistence-enabled>false</persistence-enabled>
    <journal-pool-files>10</journal-pool-files>
    <journal-device-block-size>4096</journal-device-block-size>

    <security-enabled>false</security-enabled>
    <jmx-management-enabled>true</jmx-management-enabled>

    <global-max-size>2Gb</global-max-size>
    <max-disk-usage>90</max-disk-usage>

    <acceptors>
      <!-- SSL OpenWire acceptor on port 61617 (SSL-only, no plaintext). -->
      <acceptor name="openwire-ssl">tcp://0.0.0.0:61617?protocols=OPENWIRE;sslEnabled=true;keyStorePath=/var/lib/artemis-broker/etc/certs/broker.p12;keyStorePassword=password;keyStoreType=PKCS12;trustStorePath=/var/lib/artemis-broker/etc/certs/broker-truststore.p12;trustStorePassword=password;trustStoreType=PKCS12;needClientAuth=false;tcpSendBufferSize=1048576;tcpReceiveBufferSize=1048576;connectionsAllowed=20000</acceptor>
    </acceptors>

    <addresses>
      <address name="DLQ">
        <anycast>
          <queue name="DLQ"/>
        </anycast>
      </address>
      <address name="ExpiryQueue">
        <anycast>
          <queue name="ExpiryQueue"/>
        </anycast>
      </address>
    </addresses>

    <address-settings>
      <address-setting match="#">
        <dead-letter-address>DLQ</dead-letter-address>
        <expiry-address>ExpiryQueue</expiry-address>
        <auto-create-queues>true</auto-create-queues>
        <auto-create-addresses>true</auto-create-addresses>
        <auto-delete-queues>true</auto-delete-queues>
        <auto-delete-addresses>true</auto-delete-addresses>
        <max-size-bytes>-1</max-size-bytes>
        <message-counter-history-day-limit>10</message-counter-history-day-limit>
      </address-setting>
    </address-settings>

  </core>
</configuration>
